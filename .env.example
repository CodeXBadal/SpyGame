# ===========================================
# Telegram Spy Game Bot — Environment Example
# Copy this file to `.env` and fill in real values.
# ===========================================

# --- Telegram ---
BOT_TOKEN=123456:ABCDEF-your-bot-token-here
BOT_USERNAME=YourSpyGameBot
# Comma-separated list of Telegram user IDs that have owner-only command access
OWNER_IDS=111111111,222222222

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=spygame_bot
MONGO_MAX_POOL=100
MONGO_MIN_POOL=10

# --- Game Defaults ---
MIN_PLAYERS=3
MAX_PLAYERS=12
LOBBY_COUNTDOWN=60
QUESTION_PHASE_SECONDS=300
DISCUSSION_PHASE_SECONDS=120
VOTING_PHASE_SECONDS=60
AVOID_RECENT_LOCATIONS=30

# --- Anti-Abuse ---
RATE_LIMIT_WINDOW=5
RATE_LIMIT_MAX=8
DAILY_REWARD_COOLDOWN=86400

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=bot/logs

# --- Scheduler ---
TIMEZONE=UTC

# --- Misc ---
DEBUG=false
